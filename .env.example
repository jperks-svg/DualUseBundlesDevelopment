# Cribl Search App — local environment
# Copy to .env and fill in values. .env is gitignored.

# ---- Cribl Cloud workspace ----
CRIBL_BASE_URL=https://your-workspace.cribl-staging.cloud/
CRIBL_CLIENT_ID=
CRIBL_CLIENT_SECRET=

# ---- Playwright tests ----
CRIBL_TEST_EMAIL=
CRIBL_TEST_PASSWORD=
# Override the app mount path (default: /app-ui/<app-name>/)
# CRIBL_APP_PATH=/app-ui/<app-name>/

# ---- flagd-ui (optional, for failure scenarios) ----
FLAGD_UI_URL=http://localhost:4000

{
  "name": "dual-use-bundles-dev",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "displayName": "Dual-Use Resource Bundles (Development)",
  "description": "Development branch of the Dual-Use Resource Bundles app — experimental features and new capabilities for security/observability data source guidance",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "npm run build && node scripts/package.mjs",
    "deploy": "node scripts/deploy.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.45.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright-core": "^1.45.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
